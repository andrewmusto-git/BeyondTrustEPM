# BeyondTrust PM Cloud Source Configuration
# ---------------------------------------------------------------------------
# Base URL of your BeyondTrust PM Cloud tenant.
# Example: https://your-company.pm.beyondtrustcloud.com
BT_URL=https://your-tenant.pm.beyondtrustcloud.com

# OAuth2 Client Credentials for Management API access.
# Create an API client in PM Cloud: Settings → API Registration
# Scope required: urn:management:api
BT_CLIENT_ID=your_client_id_here
BT_CLIENT_SECRET=your_client_secret_here

# Veza Configuration
# ---------------------------------------------------------------------------
VEZA_URL=https://your-company.veza.com
VEZA_API_KEY=your_veza_api_key_here

# OAA Provider Settings (optional overrides)
# ---------------------------------------------------------------------------
# PROVIDER_NAME=BeyondTrust EPM
# DATASOURCE_NAME=BeyondTrust PM Cloud
